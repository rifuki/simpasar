# ─── LLM Provider ────────────────────────────────────────────────────────────
# Pilih salah satu: "anthropic", "codex", atau "naisu"
LLM_PROVIDER=codex

# Option 1: OpenAI Codex OAuth (tidak butuh API key, gratis via subscription)
# Login dulu: bun run login:codex
# Credentials tersimpan di: apps/api/codex-credentials.json

# Option 2: Anthropic direct (butuh API key)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Option 3: Naisu Agent Gateway
NAISU_AGENT_URL=http://localhost:8787
NAISU_PROVIDER=openai-codex

# ─── Server ───────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
SKIP_PAYMENT=true
PORT=3001

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_KEY=ganti-ini-sebelum-deploy
